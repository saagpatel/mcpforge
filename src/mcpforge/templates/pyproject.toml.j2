[project]
name = "{{ plan.slug }}"
version = "{{ plan.version }}"
description = "{{ plan.description }}"
requires-python = ">=3.12"
dependencies = [
    "fastmcp>=3.1.0",
{% for pkg in plan.external_packages %}
    "{{ pkg }}",
{% endfor %}
]

[dependency-groups]
dev = ["pytest>=8.0.0", "pytest-asyncio>=0.23.0"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["."]
