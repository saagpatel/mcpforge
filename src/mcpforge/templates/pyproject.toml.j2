[project]
name = "{{ plan.slug }}"
version = "{{ plan.version }}"
description = "{{ plan.description }}"
requires-python = ">=3.12"
dependencies = [
    "fastmcp>=3.1.0",
{% for pkg in plan.external_packages %}
    "{{ pkg }}",
{% endfor %}
]

[project.scripts]
{{ plan.slug }} = "server:mcp.run"

[build-system]
requires = ["uv_build>=0.11.0,<0.12.0"]
build-backend = "uv_build"

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
